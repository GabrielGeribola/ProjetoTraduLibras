<body>

<!-- Overlay -->
<div class="overlay" id="overlay"></div>

<!-- Botão hamburguer -->
<button class="hamburger-btn" id="hamburgerBtn" aria-label="Abrir menu" aria-expanded="false">
  <span></span><span></span><span></span>
</button>

<!-- Botão configurações (engrenagem) -->
<button class="settings-btn" id="settingsBtn" aria-label="Configurações">
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="3"/>
    <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
  </svg>
</button>

<!-- Painel de configurações -->
<div class="settings-panel" id="settingsPanel">
  <div class="settings-header">
    <span>Configurações</span>
    <button class="settings-close" id="settingsClose" aria-label="Fechar">✕</button>
  </div>

  <!-- Modo escuro -->
  <div class="settings-item">
    <div class="settings-item-info">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
        <path d="M21 12.79A9 9 0 1111.21 3a7 7 0 009.79 9.79z"/>
      </svg>
      <span>Modo escuro</span>
    </div>
    <label class="toggle-switch">
      <input type="checkbox" id="darkModeToggle">
      <span class="toggle-track"><span class="toggle-thumb"></span></span>
    </label>
  </div>

  <div class="settings-divider"></div>

  <!-- Tamanho da fonte -->
  <div class="settings-item settings-item-col">
    <div class="settings-item-info">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
        <polyline points="4 7 4 4 20 4 20 7"/><line x1="9" y1="20" x2="15" y2="20"/><line x1="12" y1="4" x2="12" y2="20"/>
      </svg>
      <span>Tamanho da fonte</span>
    </div>
    <div class="font-size-control">
      <button class="font-size-btn" id="fontDecrease" aria-label="Diminuir fonte">A−</button>
      <span class="font-size-label" id="fontLabel">Médio</span>
      <button class="font-size-btn" id="fontIncrease" aria-label="Aumentar fonte">A+</button>
    </div>
  </div>
</div>

<!-- Sidebar -->
<nav class="sidebar" id="sidebar" aria-hidden="true">

  <div class="nav-linha" style="margin-top: 68px;"></div>

  <a href="/home" class="nav-link">
    <img src="https://assetstradulibras.s3.us-east-1.amazonaws.com/imgs/icon-traducao.png" class="nav-icon" alt=""/>
    <span class="link-text">Tradução</span>
  </a>
  <a href="/sugestoes" class="nav-link">
    <img src="https://assetstradulibras.s3.us-east-1.amazonaws.com/imgs/icon-sugestoes.png" class="nav-icon" alt=""/>
    <span class="link-text">Sugestões</span>
  </a>
  <a href="/cursos" class="nav-link">
    <img src="https://assetstradulibras.s3.us-east-1.amazonaws.com/imgs/icon-curso.png" class="nav-icon" alt=""/>
    <span class="link-text">Cursos</span>
  </a>

  <div class="nav-linha"></div>

  <a href="/sobre" class="nav-link">
    <img src="https://assetstradulibras.s3.us-east-1.amazonaws.com/imgs/icon-sobre.png" class="nav-icon" alt=""/>
    <span class="link-text">Sobre</span>
  </a>
  <a href="/ajuda" class="nav-link">
    <img src="https://assetstradulibras.s3.us-east-1.amazonaws.com/imgs/icon-ajuda.png" class="nav-icon" alt=""/>
    <span class="link-text">Ajuda</span>
  </a>

  <div class="nav-spacer"></div>

  <a href="/login/logout" class="nav-link nav-logout">
    <img src="https://assetstradulibras.s3.us-east-1.amazonaws.com/imgs/icon-sair.png" class="nav-icon" alt=""/>
    <span class="link-text">Sair</span>
  </a>

</nav>

<script>
  // ── Aplica preferências salvas ANTES de renderizar (evita flash) ──
  (function () {
    if (localStorage.getItem('theme') === 'dark') {
      document.documentElement.setAttribute('data-theme', 'dark');
    }
    const savedSize = localStorage.getItem('fontSize');
    if (savedSize) {
      document.documentElement.setAttribute('data-font-size', savedSize);
    }
  })();

  // ── Hamburger ────────────────────────────────────────────
  const hamburgerBtn = document.getElementById('hamburgerBtn');
  const sidebar      = document.getElementById('sidebar');
  const overlay      = document.getElementById('overlay');
  const settingsPanel = document.getElementById('settingsPanel');

  function openSidebar() {
    sidebar.classList.add('open');
    overlay.classList.add('visible');
    hamburgerBtn.classList.add('active');
    hamburgerBtn.setAttribute('aria-expanded', 'true');
    sidebar.setAttribute('aria-hidden', 'false');
    settingsPanel.classList.remove('open');
  }

  function closeSidebar() {
    sidebar.classList.remove('open');
    overlay.classList.remove('visible');
    hamburgerBtn.classList.remove('active');
    hamburgerBtn.setAttribute('aria-expanded', 'false');
    sidebar.setAttribute('aria-hidden', 'true');
  }

  hamburgerBtn.addEventListener('click', () => {
    sidebar.classList.contains('open') ? closeSidebar() : openSidebar();
  });

  overlay.addEventListener('click', () => {
    closeSidebar();
    settingsPanel.classList.remove('open');
  });

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') { closeSidebar(); settingsPanel.classList.remove('open'); }
  });

  document.querySelectorAll('.nav-link').forEach(link => {
    if (window.location.pathname.startsWith(link.getAttribute('href'))) {
      link.classList.add('active');
    }
  });

  // ── Configurações — painel ────────────────────────────────
  const settingsBtn   = document.getElementById('settingsBtn');
  const settingsClose = document.getElementById('settingsClose');

  settingsBtn.addEventListener('click', () => {
    settingsPanel.classList.toggle('open');
    closeSidebar();
  });

  settingsClose.addEventListener('click', () => settingsPanel.classList.remove('open'));

  // ── Dark Mode ─────────────────────────────────────────────
  const darkToggle = document.getElementById('darkModeToggle');
  const root       = document.documentElement;

  darkToggle.checked = root.getAttribute('data-theme') === 'dark';

  darkToggle.addEventListener('change', () => {
    if (darkToggle.checked) {
      root.setAttribute('data-theme', 'dark');
      localStorage.setItem('theme', 'dark');
    } else {
      root.removeAttribute('data-theme');
      localStorage.setItem('theme', 'light');
    }
  });

  // ── Tamanho da fonte ──────────────────────────────────────
  const SIZES  = ['pequeno', 'medio', 'grande', 'extra'];
  const LABELS = { pequeno: 'Pequeno', medio: 'Médio', grande: 'Grande', extra: 'Extra' };

  const fontDecrease = document.getElementById('fontDecrease');
  const fontIncrease = document.getElementById('fontIncrease');
  const fontLabel    = document.getElementById('fontLabel');

  function getCurrentSizeIndex() {
    const current = root.getAttribute('data-font-size') || 'medio';
    return SIZES.indexOf(current);
  }

  function applyFontSize(size) {
    root.setAttribute('data-font-size', size);
    localStorage.setItem('fontSize', size);
    fontLabel.textContent = LABELS[size];
    fontDecrease.disabled = SIZES.indexOf(size) === 0;
    fontIncrease.disabled = SIZES.indexOf(size) === SIZES.length - 1;
  }

  // Inicializa label e estado dos botões
  applyFontSize(root.getAttribute('data-font-size') || 'medio');

  fontDecrease.addEventListener('click', () => {
    const idx = getCurrentSizeIndex();
    if (idx > 0) applyFontSize(SIZES[idx - 1]);
  });

  fontIncrease.addEventListener('click', () => {
    const idx = getCurrentSizeIndex();
    if (idx < SIZES.length - 1) applyFontSize(SIZES[idx + 1]);
  });
</script>
