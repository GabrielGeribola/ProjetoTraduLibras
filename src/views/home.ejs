<%- include('includes/head'); %>

<body>
  <main>
    <%- include('includes/navbar'); %>

    <!-- Modal de Vídeo Tutorial -->
    <div class="tutorial-overlay" id="tutorialOverlay">
      <div class="tutorial-modal">
        <div class="tutorial-modal-header">
          <span>📹 Vídeo Tutorial</span>
          <button class="tutorial-close" id="tutorialClose" aria-label="Fechar">✕</button>
        </div>
        <div class="tutorial-video-wrap">
          <iframe
            id="tutorialIframe"
            src=""
            title="Tutorial TraduLibras"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen>
          </iframe>
        </div>
        <p class="tutorial-caption">Aprenda a usar o TraduLibras em poucos minutos.</p>
      </div>
    </div>

    <div class="container-home" id="homeContent">

      <!-- Cabeçalho com título e botão tutorial -->
      <div class="home-header-row">
        <h2 class="translate-home">TRADUTOR</h2>
        <button class="btn-tutorial" id="btnTutorial" aria-label="Abrir vídeo tutorial">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <polygon points="10 8 16 12 10 16 10 8" fill="currentColor" stroke="none"/>
          </svg>
          Tutorial
        </button>
      </div>

      <div class="digite-expressao">
        <p>Digite uma palavra ou expressão ou grave sua voz:</p>
      </div>

      <form id="searchForm" class="input-group">
        <input type="text" class="input-home" id="input_text" name="input_text" placeholder="Exemplo: Abraço">
        <button class="btn-home" type="submit">&gt;</button>
        <button type="button" class="btn-home" id="recordBtn">🎤 Gravar Áudio</button>
      </form>

      <div class="resultado" id="result"></div>

      <div class="feedback-container" id="feedback" style="display: none;">
        <p>Esse era o resultado esperado?</p>
        <div class="feedback-buttons">
          <button onclick="enviarFeedback(true)" class="btn-feedback btn-sim">👍 Sim</button>
          <button onclick="enviarFeedback(false)" class="btn-feedback btn-nao">👎 Não</button>
        </div>
      </div>

      <div class="buttons-cards">
        <a href="/home" class="card-traduzir">
          <p class="icon-traduzir">🔁</p>
          <h3 class="title-card">Traduzir</h3>
          <p class="descricao-card">Converta palavras em Libras de forma rápida e intuitiva.</p>
        </a>
        <a href="/cursos" class="card-aprender">
          <p class="icon-aprender">📖</p>
          <h3 class="title-card">Aprender</h3>
          <p class="descricao-card">Descubra novos sinais e amplie seu conhecimento em Libras.</p>
        </a>
        <a href="/sugestoes" class="card-incluir">
          <p class="icon-incluir">🤗</p>
          <h3 class="title-card">Incluir</h3>
          <p class="descricao-card">Facilite a comunicação e torne o diálogo mais acessível.</p>
        </a>
      </div>
    </div>

    <!-- Chat dinâmico (inicia escondido) -->
    <div id="chatWrapper" style="display: none">
      <div class="chat-container" id="chatContainer"></div>

      <form id="chatForm" class="chat-input-container" style="display:flex; gap:8px; align-items:center;">
        <input type="text" class="input-home" id="chat_input" name="chat_input" placeholder="Digite aqui..." style="flex:1;">
        <button type="button" class="btn-home" id="chatRecordBtn" title="Gravar áudio no chat">🎤</button>
        <button class="btn-home" type="submit" title="Enviar">›</button>
      </form>
    </div>

<script>
  // ── Vídeo Tutorial ────────────────────────────────────────
  // Troque a URL abaixo pelo link embed do seu tutorial (YouTube, Vimeo, etc.)
  // Exemplo YouTube: https://www.youtube.com/embed/SEU_VIDEO_ID
  const TUTORIAL_URL = 'https://assetstradulibras.s3.us-east-1.amazonaws.com/imgs/tutorial_tradulibras_com_som.mp4';

  const btnTutorial     = document.getElementById('btnTutorial');
  const tutorialOverlay = document.getElementById('tutorialOverlay');
  const tutorialClose   = document.getElementById('tutorialClose');
  const tutorialIframe  = document.getElementById('tutorialIframe');

  btnTutorial.addEventListener('click', () => {
    tutorialIframe.src = TUTORIAL_URL;
    tutorialOverlay.classList.add('open');
    document.body.style.overflow = 'hidden';
  });

  function closeTutorial() {
    tutorialOverlay.classList.remove('open');
    tutorialIframe.src = ''; // para o vídeo ao fechar
    document.body.style.overflow = '';
  }

  tutorialClose.addEventListener('click', closeTutorial);
  tutorialOverlay.addEventListener('click', e => {
    if (e.target === tutorialOverlay) closeTutorial();
  });
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') closeTutorial();
  });
  
  // ---------- CONFIGURE AQUI a URL do backend Flask ----------
  // Troque a porta se necessário (ex: 'http://localhost:5001')
  const API_BASE = '';

  const params = new URLSearchParams(window.location.search);
  const palavraUrl = params.get('word');



  // ── API / Tradutor ────────────────────────────────────────
  const API_BASE = 'http://localhost:5000';

  let ultimaEntrada  = '';
  let ultimaSugestao = '';
  let ultimoScore    = 0.0;
  let currentStream  = null;

  const resultDiv     = document.getElementById('result');
  const feedbackDiv   = document.getElementById('feedback');
  const homeContent   = document.getElementById('homeContent');
  const chatWrapper   = document.getElementById('chatWrapper');
  const chatContainer = document.getElementById('chatContainer');
  const searchForm    = document.getElementById('searchForm');
  const chatForm      = document.getElementById('chatForm');
  const chatInput     = document.getElementById('chat_input');
  const recordBtn     = document.getElementById('recordBtn');
  const chatRecordBtn = document.getElementById('chatRecordBtn');

  function appendMessage(content, sender = 'user', asHtml = false) {
    const msg = document.createElement('div');
    msg.classList.add('chat-bubble', sender);
    if (sender === 'bot' && asHtml) { msg.innerHTML = content; }
    else { msg.textContent = content; }
    chatContainer.appendChild(msg);
    chatContainer.scrollTop = chatContainer.scrollHeight;
  }

 

  // --- Envio de texto pelo input (inicial) ---
  searchForm.addEventListener('submit', async function (event) {
    event.preventDefault();
    const inputText = document.getElementById('input_text').value.trim();
    if (!inputText) return;
    homeContent.style.display = 'none';
    chatWrapper.style.display = 'block';
    chatInput.value = inputText;
    chatForm.dispatchEvent(new Event('submit'));
  });

  chatForm.addEventListener('submit', async function (event) {
    event.preventDefault();
    const inputText = chatInput.value.trim();
    if (!inputText) return;
    ultimaEntrada = inputText;
    appendMessage(inputText, 'user');
    chatInput.value = '';
    try {
      const response = await fetch(`${API_BASE}/api/sugestao`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ texto: inputText })
      });
      let data;
      try { data = await response.json(); }
      catch (err) { appendMessage('Erro do servidor ao buscar sugestão.', 'bot'); return; }
      if (response.ok) {
        ultimaSugestao = data.expressao;
        ultimoScore    = data.score ?? 0.0;
        const botMessage = `
          <p><strong>${data.expressao}</strong></p>
          <p>Nível de confiança: ${data.nivel_confianca}</p>
          <div class="video-container">
            <video controls>
              <source src="${data.url}" type="video/mp4">
              Seu navegador não suporta vídeo.
            </video>
          </div>
          <div class="feedback-inline">
            <span>Esse era o resultado esperado?</span>
            <button onclick="enviarFeedback(true)">👍</button>
            <button onclick="enviarFeedback(false)">👎</button>
          </div>`;
        appendMessage(botMessage, 'bot', true);
      } else {
        appendMessage(data.mensagem || 'Erro ao buscar expressão.', 'bot');
      }
    } catch (err) {
      appendMessage('Erro de rede ao buscar expressão.', 'bot');
    }
  });

  async function enviarFeedback(foiUtil) {
    try {
      const response = await fetch(`${API_BASE}/api/feedback`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ entrada: ultimaEntrada, sugestao: ultimaSugestao, score: ultimoScore, foi_util: foiUtil })
      });
      let data;
      try { data = await response.json(); } catch (err) { appendMessage('Erro ao enviar feedback.', 'bot'); return; }
      appendMessage(data.mensagem || 'Feedback recebido!', 'bot');
    } catch (err) { appendMessage('Erro ao enviar feedback.', 'bot'); }
  }

  // Gravação tela inicial
  recordBtn.addEventListener('click', async () => {
    recordBtn.disabled = true; recordBtn.textContent = '🎙️ Gravando...';
    try {
      const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
      currentStream = stream;
      const mediaRecorder = new MediaRecorder(stream);
      const chunks = [];
      mediaRecorder.ondataavailable = e => chunks.push(e.data);
      mediaRecorder.onstop = async () => {
        try { if (currentStream) { currentStream.getTracks().forEach(t => t.stop()); currentStream = null; } } catch(e){}
        const blob = new Blob(chunks, { type: 'audio/webm' });
        const formData = new FormData();
        formData.append('file', blob, 'recording.webm');
        appendMessage('Enviando áudio para transcrição...', 'bot');
        let response;
        try { response = await fetch(`${API_BASE}/api/transcrever`, { method: 'POST', body: formData }); }
        catch (err) { appendMessage('Erro de rede ao enviar áudio.', 'bot'); recordBtn.disabled = false; recordBtn.textContent = '🎤 Gravar Áudio'; return; }
        if (!response.ok) { appendMessage('Erro ao transcrever (status ' + response.status + ')', 'bot'); recordBtn.disabled = false; recordBtn.textContent = '🎤 Gravar Áudio'; return; }
        let data;
        try { data = await response.json(); } catch (err) { appendMessage('Resposta inválida do servidor.', 'bot'); recordBtn.disabled = false; recordBtn.textContent = '🎤 Gravar Áudio'; return; }
        if (data.texto) {
          homeContent.style.display = 'none'; chatWrapper.style.display = 'block';
          chatInput.value = data.texto;
          appendMessage(`Transcrição: "${data.texto}"`, 'bot');
          setTimeout(() => chatForm.dispatchEvent(new Event('submit')), 100);
        } else { appendMessage(data.mensagem || 'Não foi possível transcrever o áudio.', 'bot'); }
        recordBtn.disabled = false; recordBtn.textContent = '🎤 Gravar Áudio';
      };
      mediaRecorder.start();
      appendMessage('🎤 Gravando áudio por 5 segundos...', 'bot');
      setTimeout(() => { if (mediaRecorder.state !== 'inactive') mediaRecorder.stop(); }, 5000);
    } catch (err) { appendMessage('Permissão negada ou erro ao acessar microfone.', 'bot'); recordBtn.disabled = false; recordBtn.textContent = '🎤 Gravar Áudio'; }
  });

  // Gravação no chat
  chatRecordBtn.addEventListener('click', async () => {
    chatRecordBtn.disabled = true; chatRecordBtn.textContent = '🎙️';
    try {
      const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
      currentStream = stream;
      const mediaRecorder = new MediaRecorder(stream);
      const chunks = [];
      mediaRecorder.ondataavailable = e => chunks.push(e.data);
      mediaRecorder.onstop = async () => {
        try { currentStream.getTracks().forEach(t => t.stop()); currentStream = null; } catch(e){}
        const blob = new Blob(chunks, { type: 'audio/webm' });
        const formData = new FormData();
        formData.append('file', blob, 'chat_recording.webm');
        appendMessage('Enviando áudio para transcrição...', 'bot');
        let response;
        try { response = await fetch(`${API_BASE}/api/transcrever`, { method: 'POST', body: formData }); }
        catch (err) { appendMessage('Erro de rede ao enviar áudio.', 'bot'); chatRecordBtn.disabled = false; chatRecordBtn.textContent = '🎤'; return; }
        if (!response.ok) { appendMessage('Erro ao transcrever (status ' + response.status + ')', 'bot'); chatRecordBtn.disabled = false; chatRecordBtn.textContent = '🎤'; return; }
        let data;
        try { data = await response.json(); } catch (err) { appendMessage('Resposta inválida do servidor.', 'bot'); chatRecordBtn.disabled = false; chatRecordBtn.textContent = '🎤'; return; }
        if (data.texto) {
          homeContent.style.display = 'none'; chatWrapper.style.display = 'block';
          chatInput.value = data.texto;
          appendMessage(`Transcrição: "${data.texto}"`, 'bot');
          setTimeout(() => chatForm.dispatchEvent(new Event('submit')), 100);
        } else { appendMessage(data.mensagem || 'Não foi possível transcrever o áudio.', 'bot'); }
        chatRecordBtn.disabled = false; chatRecordBtn.textContent = '🎤';
      };
      mediaRecorder.start();
      appendMessage('🎤 Gravando áudio por 5 segundos...', 'bot');
      setTimeout(() => { if (mediaRecorder.state !== 'inactive') mediaRecorder.stop(); }, 5000);
    } catch (err) { appendMessage('Permissão negada ou erro ao acessar microfone.', 'bot'); chatRecordBtn.disabled = false; chatRecordBtn.textContent = '🎤'; }
  });

     // Verifica se veio palavra pela URL
 let autoTraducaoExecutada = false;

window.addEventListener('DOMContentLoaded', () => {
  if (autoTraducaoExecutada) return;
  const params = new URLSearchParams(window.location.search);
  const word = params.get('word');

  if (word) {

    autoTraducaoExecutada = true;
    document.getElementById('input_text').value = word;
    document.getElementById('searchForm')
      .dispatchEvent(new Event('submit'));
  }
});
</script>
</main>
</body>
