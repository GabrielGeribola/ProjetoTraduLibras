<%- include('includes/head') %>
<%- include('includes/navbar') %>

<style>
  .sugestoes-container {
    max-width: 800px;
    margin: 40px auto;
    background: #fff;
    padding: 30px;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    font-family: Arial, sans-serif;
  }

  .sugestoes-title {
    font-size: 2rem;
    text-align: center;
    color: #1e293b;
    margin-bottom: 20px;
    border-bottom: 2px solid #3b82f6;
    padding-bottom: 10px;
  }

  .scroll-area {
    max-height: 400px; /* ajuste conforme necessário */
    overflow-y: auto;
    padding-right: 10px;
  }

  .sugestoes-list {
    list-style: decimal inside;
    font-size: 18px;
    color: #0f172a;
    line-height: 1.8;
    padding-left: 10px;
  }

  .sugestoes-list li {
    margin-bottom: 10px;
  }

  .sugestoes-image {
    text-align: center;
    margin-top: 30px;
  }

  .sugestoes-image img {
    width: 200px;
  }

@media (max-width: 480px) {
  .sugestoes-container {
    margin: 20px 10px 10px 80px;
    padding: 20px 15px;
    border-radius: 10px;
  }

  .sugestoes-title {
    font-size: 1.5rem;
    padding-bottom: 8px;
  }

  .scroll-area {
    max-height: 300px;
    padding-right: 5px;
  }

  .sugestoes-list {
    font-size: 16px;
    line-height: 1.6;
    padding-left: 5px;
  }

  .sugestoes-image img {
    width: 120px;
  }
}


</style>

<div class="sugestoes-container">
  <div class="sugestoes-title">Sugestões</div>

  <div class="scroll-area">
    <div id="glossario-container"></div>
  </div>

  <div class="sugestoes-image">
    <img src="https://cdn-icons-png.flaticon.com/512/6614/6614671.png" alt="Sugestões">
  </div>
</div>

<script src="/assets/js/glossario.js"></script>
<%- include('includes/footer') %>
