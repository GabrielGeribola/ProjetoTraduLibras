<%- include('includes/head') %>
<%- include('includes/navbar') %>

<div class="page-container">
  <div class="content-card">

    <div class="header">
      <h1>Cursos</h1>
      <input type="text" class="search-bar" placeholder="🔍 Buscar cursos">
    </div>

    <div class="scrollable-content">

      <!-- Artigos Didáticos -->
      <div class="toggle-section">
        <h2 class="section-header">📄 Artigos Didáticos</h2>
        <div class="topics-container section-content">
          <% artigos.forEach(artigo => { %>
          <div class="topic">
            <h3><%= artigo.titulo %></h3>
            <p><%= artigo.descricao %></p>
            <a href="<%= artigo.link %>" target="_blank" class="btn-topic">📄 Ler artigo</a>
          </div>
          <% }) %>
        </div>
      </div>

      <!-- Vídeos Didáticos -->
      <div class="toggle-section">
        <h2 class="section-header">🎬 Vídeos Didáticos</h2>
        <div class="topics-container section-content">
          <% videos.forEach(video => { %>
          <div class="topic">
            <h3><%= video.titulo %></h3>
            <p><%= video.descricao %></p>
            <a href="<%= video.link %>" target="_blank" class="btn-topic">▶️ Assistir vídeo</a>
          </div>
          <% }) %>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
  document.querySelectorAll('.section-header').forEach(header => {
    header.addEventListener('click', () => {
      header.parentElement.classList.toggle('open');
    });
  });
</script>

<%- include('includes/footer') %>
